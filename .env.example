# LLM Provider Configuration
# Options: openai, anthropic, xai
LLM_PROVIDER=openai

# Model names (optional - defaults will be used if not specified)
# For OpenAI: gpt-4o, gpt-4o-mini, etc.
# For Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229, etc.
# For xAI: grok-2-1212, grok-2-vision-1212, grok-4-0117, etc.
LLM_MODEL=

# API Keys (required based on your chosen provider)
# OpenAI API Key (for GPT models)
OPENAI_API_KEY=sk-your-openai-key-here

# Anthropic API Key (for Claude models)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# xAI API Key (for Grok models)
XAI_API_KEY=your-xai-key-here