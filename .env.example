# Multi-LLM Provider Configuration
# The system will use these providers in fallback order if one fails:
# xAI Grok -> Google Gemini -> OpenAI GPT -> Anthropic Claude -> MiniMax -> Ollama (local)
# Set as many API keys as you have available.

# Priority 1: xAI Grok
XAI_API_KEY=your-xai-key-here
LLM_MODEL_XAI=grok-2-1212

# Priority 2: Google Gemini
GOOGLE_API_KEY=your-google-api-key-here
LLM_MODEL_GEMINI=gemini-1.5-flash

# Priority 3: OpenAI GPT
OPENAI_API_KEY=sk-your-openai-key-here
LLM_MODEL_OPENAI=gpt-4o

# Priority 4: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
LLM_MODEL_ANTHROPIC=claude-3-5-sonnet-20241022

# Priority 5: MiniMax
MINIMAX_API_KEY=your-minimax-key-here
MINIMAX_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL_MINIMAX=abab6.5s-chat

# Priority 6: Ollama (Local)
# Set this to your Ollama endpoint (e.g., http://localhost:11434)
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL_OLLAMA=llama3